---
import "@/styles/global.css"
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>The License — source-available done warm</title>
    <meta name="description" content="Open source is magic. It's also not free. The License is a source-available license that makes sharing sustainable — no doom, no gloom, just a better way." />
  </head>
  <body class="min-h-svh flex flex-col">
    <header class="border-b border-border/50">
      <div class="mx-auto flex h-14 max-w-4xl items-center justify-between px-5">
        <div class="flex items-center gap-3">
          <a href="/" class="text-lg font-medium tracking-tight text-primary hover:opacity-80 transition-opacity">
            The License
          </a>
        </div>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/blog" class="text-muted-foreground hover:text-foreground transition-colors">
            Blog
          </a>
          <a
            href="https://discord.awfixer.me"
            class="inline-flex items-center gap-1.5 rounded-lg bg-primary/10 px-3 py-1.5 text-primary hover:bg-primary/20 transition-colors"
          >
            <span>💬</span>
            <span class="hidden sm:inline">Discord</span>
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border/50 py-8">
      <div class="mx-auto max-w-4xl px-5 text-center text-sm text-muted-foreground">
        <p class="mb-2">
          Made with ☕ and mild takes about the economics of digital commons.
        </p>
        <p class="mb-3">
          <a href="https://discord.awfixer.me" class="text-primary underline underline-offset-2 hover:no-underline">
            Join the Discord
          </a>
          {' '}·{' '}
          <a href="/blog" class="text-primary underline underline-offset-2 hover:no-underline">
            Blog
          </a>
        </p>
        <p>
          Not a lawyer. This is not legal advice. Your mileage may vary. Batteries not included.
        </p>
      </div>
    </footer>
  </body>
</html>

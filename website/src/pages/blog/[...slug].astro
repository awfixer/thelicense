---
import Layout from "@/layouts/main.astro"
import { getCollection, render, type CollectionEntry } from "astro:content"
import type { GetStaticPathsItem } from "astro"

interface Props {
  post: CollectionEntry<"blog">
}

export async function getStaticPaths(): Promise<GetStaticPathsItem[]> {
  const posts = await getCollection("blog", ({ data }) => !data.draft)
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props as Props
const { Content } = await render(post)
---

<Layout>
  <article class="mx-auto max-w-2xl px-5 pt-16 pb-24">
    <a
      href="/blog"
      class="mb-8 inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← Back to blog
    </a>

    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-balance">{post.data.title}</h1>
      <p class="mt-2 text-sm text-muted-foreground">{post.data.description}</p>
      <div class="mt-4 flex items-center gap-3 text-xs text-muted-foreground">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        <span>·</span>
        <span>{post.data.author}</span>
      </div>
    </header>

    <div class="prose-custom text-sm leading-relaxed text-foreground [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:no-underline [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:tracking-tight [&_p]:mb-4 [&_p]:leading-relaxed [&_ul]:mb-4 [&_ul]:pl-5 [&_ul]:space-y-1 [&_li]:text-sm [&_code]:rounded [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-xs [&_strong]:font-semibold">
      <Content />
    </div>

    <div class="mt-16 rounded-xl border border-border bg-card p-5 text-center text-sm text-muted-foreground">
      <p class="leading-relaxed">
        Want to respond? Join the <a href="https://discord.awfixer.me" class="text-primary underline underline-offset-2 hover:no-underline">Discord</a>
        {' '}and join the conversation. Ask to be featured on the blog.
      </p>
    </div>
  </article>
</Layout>
